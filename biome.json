{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "files": {
    "includes": [
      "src/**",
      "docs/**",
      "vite.config.ts",
      "biome.json",
      "package.json",
      "index.html",
      "tsconfig.json",
      "tsconfig.app.json",
      "tsconfig.node.json"
    ]
  },
  "formatter": {
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  }
}
